{
  "name": "@modern-edu/realtime",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Modern Edu realtime gateway — Socket.IO + Redis fan-out",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@modern-edu/contracts": "workspace:*",
    "@modern-edu/db": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "drizzle-orm": "^0.38.3",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@modern-edu/config": "workspace:*",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
